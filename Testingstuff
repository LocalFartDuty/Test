-- Function to ask user for key input
function AskForKey()
    -- Create a GUI to ask for the key
    local ScreenGui = Instance.new("ScreenGui")
    local InputBox = Instance.new("TextBox")
    local SubmitButton = Instance.new("TextButton")

    ScreenGui.Parent = game.CoreGui
    ScreenGui.Name = "KeyInputScreen"
    
    InputBox.Parent = ScreenGui
    InputBox.Size = UDim2.new(0, 300, 0, 50)
    InputBox.Position = UDim2.new(0.5, -150, 0.5, -25)
    InputBox.PlaceholderText = "Enter your key"
    InputBox.Text = ""
    InputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    InputBox.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

    SubmitButton.Parent = ScreenGui
    SubmitButton.Size = UDim2.new(0, 100, 0, 50)
    SubmitButton.Position = UDim2.new(0.5, -50, 0.5, 30)
    SubmitButton.Text = "Submit"
    SubmitButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)

    -- Wait for user to submit the key
    SubmitButton.MouseButton1Click:Connect(function()
        getgenv().InputKey = InputBox.Text
        if getgenv().InputKey == getgenv().ValidKey then
            IsAuthenticated = true
            ScreenGui:Destroy() -- Remove the key input screen
        else
            -- Show a message if the key is incorrect
            local IncorrectLabel = Instance.new("TextLabel")
            IncorrectLabel.Parent = ScreenGui
            IncorrectLabel.Size = UDim2.new(0, 300, 0, 50)
            IncorrectLabel.Position = UDim2.new(0.5, -150, 0.5, 100)
            IncorrectLabel.Text = "Invalid Key!"
            IncorrectLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            IncorrectLabel.BackgroundTransparency = 1
        end
    end)
end

--// Ensure key input is received before proceeding
AskForKey()

-- Main script won't continue until user is authenticated
while not IsAuthenticated do
    wait(0.5) -- Check every 0.5 seconds for authentication
end

