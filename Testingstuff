--// Hitbox-based Prediction Adjustments for DaHood Knockoffs
function AdjustPredictionBasedOnHitbox(player)
    local targetCharacter = player.Character
    if targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart") then
        local hitboxSize = targetCharacter.HumanoidRootPart.Size.Magnitude  -- Base size of HumanoidRootPart
        local headSize = targetCharacter:FindFirstChild("Head") and targetCharacter.Head.Size.Magnitude or 0
        local torsoSize = targetCharacter:FindFirstChild("Torso") and targetCharacter.Torso.Size.Magnitude or 0

        -- Combine sizes of major hitbox parts (HumanoidRootPart, Head, Torso)
        local totalHitboxSize = hitboxSize + headSize + torsoSize

        -- Adjust prediction based on total hitbox size (larger hitboxes = higher prediction)
        if totalHitboxSize <= 1 then
            return 0.12
        elseif totalHitboxSize <= 2 then
            return 0.13
        elseif totalHitboxSize <= 3 then
            return 0.14
        elseif totalHitboxSize <= 4 then
            return 0.15
        elseif totalHitboxSize <= 5 then
            return 0.16
        elseif totalHitboxSize <= 6 then
            return 0.17
        elseif totalHitboxSize <= 7 then
            return 0.18
        elseif totalHitboxSize <= 8 then
            return 0.19
        elseif totalHitboxSize <= 9 then
            return 0.20
        elseif totalHitboxSize <= 10 then
            return 0.21
        elseif totalHitboxSize <= 11 then
            return 0.22
        elseif totalHitboxSize <= 12 then
            return 0.23
        elseif totalHitboxSize <= 13 then
            return 0.24
        elseif totalHitboxSize <= 14 then
            return 0.25
        elseif totalHitboxSize <= 15 then
            return 0.26
        elseif totalHitboxSize <= 16 then
            return 0.27
        elseif totalHitboxSize <= 17 then
            return 0.28
        elseif totalHitboxSize <= 18 then
            return 0.29
        elseif totalHitboxSize <= 19 then
            return 0.30
        elseif totalHitboxSize <= 20 then
            return 0.31
        else
            return 0.32
        end
    end
    return 0.18 -- Default prediction if hitbox is not found
end

--// Ping-based Prediction Adjustment
function AdjustPredictionBasedOnPing()
    local ping = tonumber(string.match(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString(), "%d+"))
    -- Scale prediction starting from 50ms
    local prediction = 0.12
    if ping > 50 then
        prediction = 0.12 + ((ping - 50) / 10) * 0.02  -- Increase prediction by 0.02 per 10ms after 50ms
    end
    -- Cap the prediction value to a maximum of 0.30 for ping higher than 300ms
    return math.min(prediction, 0.30)
end

function CombinePredictions(hitboxPrediction, pingPrediction)
    -- Combine both predictions with some weighting
    local finalPrediction = (hitboxPrediction + pingPrediction) / 2
    return finalPrediction
end

--// Jump Offset Calculation
function GetJumpOffset(player)
    local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
    if humanoid and humanoid:GetState() == Enum.HumanoidStateType.Jumping then
        local velocity = player.Character.HumanoidRootPart.AssemblyLinearVelocity
        -- Calculate the predicted jump offset based on velocity
        local jumpOffset = velocity.Y * 0.1 -- Basic scale factor for Y velocity
        return jumpOffset
    end
    return 0.11 -- Fallback if not jumping
end

function SmoothLockOntoTarget()
    if Victim and Victim.Character and AimlockState and HoldingKey then
        local targetPart = Victim.Character:FindFirstChild(getgenv().AimPart)
        if targetPart then
            -- Apply prediction based on the target's hitbox size
            local hitboxPrediction = AdjustPredictionBasedOnHitbox(Victim)
            -- Apply prediction based on the ping
            local pingPrediction = AdjustPredictionBasedOnPing()
            -- Combine both hitbox and ping predictions
            local combinedPrediction = CombinePredictions(hitboxPrediction, pingPrediction)

            -- Jump offset adjustment if enabled
            local jumpOffset = getgenv().AutoJumpOffset and GetJumpOffset(Victim) or 0.11

            -- Apply the jump offset to the target's position
            local targetPosition = targetPart.Position + targetPart.Velocity * combinedPrediction + Vector3.new(0, jumpOffset, 0)
            local smoothPos = Camera.CFrame.Position:Lerp(CFrame.new(Camera.CFrame.Position, targetPosition).Position, getgenv().Smoothness)
            Camera.CFrame = CFrame.new(smoothPos, targetPosition)
        else
            Victim = nil
        end
    end
end

--// Event Listeners
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == getgenv().Key then
        HoldingKey = true
        Victim = GetClosest()
    elseif not gameProcessed and input.KeyCode == getgenv().DisableKey then
        AimlockState = not AimlockState
    elseif not gameProcessed and input.KeyCode == Enum.KeyCode.N then
        -- Toggle between Head and HumanoidRootPart
        if getgenv().AimPart == "HumanoidRootPart" then
            getgenv().AimPart = "Head"
        else
            getgenv().AimPart = "HumanoidRootPart"
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == getgenv().Key then
        HoldingKey = false
        Victim = nil
    end
end)

RunService.RenderStepped:Connect(function()
    UpdateFOV()
    if getgenv().AutoPrediction then
        -- Adjusting the prediction based on ping and hitbox is handled separately
    end
    SmoothLockOntoTarget()
end)
